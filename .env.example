# Переменные окружения для Vercel

# API Secret - случайная строка для защиты API (сгенерируйте надежный ключ)
API_SECRET=your_random_secret_key_here

# Пароль администратора для доступа к панели
ADMIN_PASSWORD=your_admin_password_here

# Путь к базе данных SQLite (для Vercel оставьте как есть)
DATABASE_PATH=./data/proxy.db
